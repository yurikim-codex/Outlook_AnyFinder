# OutLook AnyFinder .gitignore
# Keep source/build scripts/docs, ignore generated/local artifacts.

# Python cache / bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class

# Python build / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage/
htmlcov/
.tox/
.nox/

# PyInstaller temporary files
*.manifest
*.spec~
# NOTE: Do NOT ignore *.spec globally because OutLookAnyFinder.spec is required.

# Release outputs - generated packages should not be committed
release/
*.zip
*.7z
*.rar
*.exe
*.msi

# Local app data / databases
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# Logs
*.log
logs/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Local env files
.env
.env.*

# User-specific config backups / local-only files
config.local.json
